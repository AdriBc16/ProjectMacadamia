<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/elegir"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivity"
    >

    <ImageView
        android:id="@+id/fondoBlancoConDisenio"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:alpha="0.3"
        android:contentDescription="@string/whitewallpaper"
        android:scaleType="centerCrop"
        android:src="@drawable/fondo_inicio" />

    <ImageView
        android:id="@+id/yourcookieday"
        android:layout_width="352dp"
        android:layout_height="350dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="96dp"
        android:contentDescription="@string/yourcookieday"
        android:src="@drawable/yourcookieday" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="bottom|center_horizontal"
        android:orientation="horizontal"
        android:paddingStart="32dp"
        android:paddingEnd="32dp">

        <Button
            android:id="@+id/botonRegister"
            style="@style/BotonVerdeOscuro"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            android:layout_marginBottom="120dp"
            android:text="@string/registrarse" />

        <Button
            android:id="@+id/botonLogIn"
            style="@style/BotonVerdeOscuro"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:layout_marginBottom="120dp"
            android:text="@string/inicioSesion" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|center_horizontal"
        android:orientation="horizontal"
        android:paddingStart="32dp"
        android:paddingEnd="32dp">

        <Button
            style="@style/BotonGoogle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginBottom="180dp"
            android:layout_weight="1"
            android:text="@string/google"
            app:icon="@drawable/google_logo"
            app:iconTintMode="multiply"
            app:iconGravity = "textStart" />
    </LinearLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/ups"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginBottom="165dp">
    </TextView>
</FrameLayout>




